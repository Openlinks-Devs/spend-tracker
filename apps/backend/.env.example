DATABASE_URL=postgres://user:pass@host:5432/spendtracker
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
GOOGLE_REFRESH_TOKEN=
GMAIL_POLL_INTERVAL_MS=60000
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
PORT=3000
TZ=America/Lima
# Better Auth: base URL the backend serves from, and a secret of at least 32
# chars (generate with `openssl rand -hex 32`).
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
# mock synthesizes a demo session and skips Google sign-in (use for local/LAN
# preview); live requires real Better Auth + Google OAuth. Defaults to mock.
APP_MODE=mock
# Comma-separated emails allowed to sign in (live mode). Defaults to the owner.
ALLOWED_EMAILS=
